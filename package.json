{
  "name": "muzhiyu",
  "version": "1.0.0",
  "description": "墓之语 — HTML5 Canvas 2D 开放世界探索 RPG",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"node server.js\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src server.js scripts",
    "format": "prettier --write \"src/**/*.js\" \"server.js\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.js\" \"server.js\" \"scripts/**/*.mjs\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "three": "^0.171.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
